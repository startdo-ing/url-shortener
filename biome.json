{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "javascript": {
    "experimentalEmbeddedSnippetsEnabled": true,
    "formatter": {
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "linter": {
    "rules": {
      "correctness": {
        "noUnusedImports": "error"
      }
    }
  }
}
