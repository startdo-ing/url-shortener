# Copy to `.env.docker` for `docker compose --env-file .env.docker up --build`.

# bcrypt hash from: `bun -e 'console.log(await Bun.password.hash("your-password"))'`
PORTAL_AUTH_HASH=

# Short links as seen by visitors (scheme + host, no trailing slash). Default matches compose port map.
PUBLIC_SHORT_BASE_URL=http://localhost:3000

REDIRECT_PUBLISH_PORT=3000
PORTAL_PUBLISH_PORT=4321

REDIRECT_RATE_LIMIT_ENABLED=true
REDIRECT_RATE_LIMIT_WINDOW_MS=60000
REDIRECT_RATE_LIMIT_MAX=120
TRUST_PROXY_HOPS=0
