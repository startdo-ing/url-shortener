# Postgres (migrate + redirect)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/url_shortener

# Portal (Astro dev default 4321 — see apps/portal/package.json)
# Same DATABASE_URL for migrate + portal + redirect

# Public short host for QR codes (F-008, R-037) — no trailing slash
# PUBLIC_SHORT_BASE_URL=https://c.anh.pw

# Portal session gate (F-009, R-034). Default off — use with HTTPS in production.
# AUTH_MODE=session
# bcrypt hash of operator password (generate: bun -e 'console.log(await Bun.password.hash("your-secret"))')
# PORTAL_AUTH_HASH=$2b$10$...

# Redirect app bind
HOST=0.0.0.0
PORT=3000

# Trusted reverse-proxy hops for X-Forwarded-For (0 = use socket IP only)
TRUST_PROXY_HOPS=0

# Optional GeoLite2-City .mmdb for async click enrichment (F-005)
# GEOIP_CITY_DB=/path/to/GeoLite2-City.mmdb

# Optional: store whitelisted request headers on click_events.raw_headers (default off)
# RAW_HEADERS_ENABLED=true
