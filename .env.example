# Postgres (migrate + redirect)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/url_shortener

# Portal (Astro dev default 4321 — see apps/portal/package.json)
# Same DATABASE_URL for migrate + portal + redirect

# Redirect app bind
HOST=0.0.0.0
PORT=3000

# Trusted reverse-proxy hops for X-Forwarded-For (0 = use socket IP only)
TRUST_PROXY_HOPS=0
