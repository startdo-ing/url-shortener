{
	"servers": {
		"Astro docs": {
			"url": "https://mcp.docs.astro.build/mcp",
			"type": "http"
		},
		"dev.svelte/mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sveltejs/mcp@0.1.22"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.1.22"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}