{
	"servers": {
		"Astro docs": {
			"url": "https://mcp.docs.astro.build/mcp",
			"type": "http"
		},
		"dev.svelte/mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sveltejs/mcp@0.1.22"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.1.22"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.3"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.3"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}