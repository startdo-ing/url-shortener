---
import NotesEditor from "../../components/NotesEditor.svelte";
import Layout from "../../layouts/Layout.astro";
import { listUtmTemplates } from "../../server/marketer";

let templates = [] as import("../../server/marketer").UtmTemplateRow[];
try {
  templates = await listUtmTemplates();
} catch {
  templates = [];
}

const codes: Record<string, string> = {
  invalid_destination: "Invalid destination URL (only http and https links are allowed).",
  invalid_slug:
    "Custom slug invalid — use 1–128 characters: letters, digits, hyphen, underscore.",
  duplicate_slug: "That slug is already taken. Pick another.",
  invalid_expires: "Expiry date/time is invalid. Use the picker or leave empty.",
  notes_too_large: "Notes exceed 64KB (UTF-8). Shorten and try again.",
};

const raw = Astro.url.searchParams.get("error");
const errorBanner = raw ? codes[raw] ?? "Could not save link." : null;
---

<Layout title="New link" errorBanner={errorBanner}>
  <div class="toolbar">
    <h1 style="margin:0">New link</h1>
    <div style="display:flex; gap:12px; align-items:center">
      <a href="/utm">UTM</a>
      <a href="/tags">Tags</a>
      <a href="/">&larr; Back</a>
    </div>
  </div>
  <div class="card">
    <form method="post" action="/api/create-link">
      <div class="field">
        <label for="destination_url">destination URL</label>
        <input id="destination_url" name="destination_url" required type="url" placeholder="https://…" />
      </div>
      <div class="field">
        <label for="utm_template_id">UTM template (optional)</label>
        <select id="utm_template_id" name="utm_template_id">
          <option value="">— none —</option>
          {templates.map((t) => (
            <option value={t.id}>{t.name}</option>
          ))}
        </select>
        <p class="label" style="margin:8px 0 0; color:var(--secondary)">
          On save, selected parameters are merged into the destination URL.
        </p>
      </div>
      <div class="field">
        <label for="tags">tags (optional, comma-separated)</label>
        <input id="tags" name="tags" type="text" placeholder="launch, q4" autocomplete="off" />
      </div>
      <div class="field">
        <label for="slug">custom slug (optional)</label>
        <input id="slug" name="slug" placeholder="leave blank for random id" autocomplete="off" />
      </div>
      <div class="field">
        <label for="redirect_type">redirect</label>
        <select id="redirect_type" name="redirect_type">
          <option value="302">302 temporary</option>
          <option value="301">301 permanent</option>
        </select>
      </div>
      <div class="field">
        <label for="status">status</label>
        <select id="status" name="status">
          <option value="active">active</option>
          <option value="paused">paused</option>
        </select>
      </div>
      <div class="field">
        <label for="display_title">display title (optional)</label>
        <input id="display_title" name="display_title" type="text" />
      </div>
      <div class="field">
        <label for="expires_at">expires at (optional, UTC)</label>
        <input id="expires_at" name="expires_at" type="datetime-local" />
      </div>
      <div class="field">
        <label for="notes_markdown_field">notes (markdown)</label>
        <NotesEditor client:load initialMarkdown="" />
      </div>
      <button class="btn-primary" type="submit">Save link</button>
    </form>
  </div>
</Layout>
