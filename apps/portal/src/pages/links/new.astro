---
import Layout from "../../layouts/Layout.astro";

const codes: Record<string, string> = {
  invalid_destination: "Invalid destination URL (only http and https links are allowed).",
  invalid_slug:
    "Custom slug invalid — use 1–128 characters: letters, digits, hyphen, underscore.",
  duplicate_slug: "That slug is already taken. Pick another.",
};

const raw = Astro.url.searchParams.get("error");
const errorBanner = raw ? codes[raw] ?? "Could not save link." : null;
---

<Layout title="New link" errorBanner={errorBanner}>
  <div class="toolbar">
    <h1 style="margin:0">New link</h1>
    <a href="/">&larr; Back</a>
  </div>
  <div class="card">
    <form method="post" action="/api/create-link">
      <div class="field">
        <label for="destination_url">destination URL</label>
        <input id="destination_url" name="destination_url" required type="url" placeholder="https://…" />
      </div>
      <div class="field">
        <label for="slug">custom slug (optional)</label>
        <input id="slug" name="slug" placeholder="leave blank for random id" autocomplete="off" />
      </div>
      <div class="field">
        <label for="redirect_type">redirect</label>
        <select id="redirect_type" name="redirect_type">
          <option value="302">302 temporary</option>
          <option value="301">301 permanent</option>
        </select>
      </div>
      <div class="field">
        <label for="status">status</label>
        <select id="status" name="status">
          <option value="active">active</option>
          <option value="paused">paused</option>
        </select>
      </div>
      <div class="field">
        <label for="display_title">display title (optional)</label>
        <input id="display_title" name="display_title" type="text" />
      </div>
      <div class="field">
        <label for="notes_markdown">notes — markdown supported in a later slice</label>
        <textarea id="notes_markdown" name="notes_markdown" />
      </div>
      <button class="btn-primary" type="submit">Save link</button>
    </form>
  </div>
</Layout>
