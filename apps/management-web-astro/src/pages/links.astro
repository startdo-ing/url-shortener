---
import Layout from "../components/Layout.astro"
import FlashBanners from "../components/ui/FlashBanners.astro"
import CreateLinkDialog from "../components/links/CreateLinkDialog.astro"
import LinkFilterForm from "../components/links/LinkFilterForm.astro"
import LinksTable from "../components/links/LinksTable.astro"
import { loadPageContext } from "../lib/page"
import {
	listLinkDomains,
	listLinks,
	type LinkFilters
} from "../lib/models/link"

function readFilters(url: URL): LinkFilters {
	const status = url.searchParams.get("status")
	const query = url.searchParams.get("query")?.trim() || undefined
	const domainId = url.searchParams.get("domainId")?.trim() || undefined

	return {
		domainId,
		query,
		status: status === "active" || status === "disabled" ? status : undefined
	}
}

const filters = readFilters(Astro.url)
const [{ viewer, error, notice }, domains, links] = await Promise.all([
	loadPageContext(Astro.request, Astro.response),
	listLinkDomains(),
	listLinks(filters)
])
---

<Layout title="Short Links" viewer={viewer}>
	<section>
		<h1>Short Links</h1>
		<FlashBanners error={error} notice={notice} />
		<p>Create, search, update, and delete redirect links for the configured domains.</p>
		<LinkFilterForm domains={domains} filters={filters} />
		<CreateLinkDialog domains={domains} />
		<LinksTable links={links} domains={domains} />
	</section>
</Layout>
