---
import Layout from "../../components/Layout.astro"
import FlashBanners from "../../components/ui/FlashBanners.astro"
import { RETURN_TO_PARAM } from "../../lib/auth/constants"
import { getAuthDiagnostics } from "../../lib/auth/config"
import { loadPageContext } from "../../lib/page"

const { viewer, error, notice } = await loadPageContext(
	Astro.request,
	Astro.response
)
const diagnostics = getAuthDiagnostics()
const returnTo = Astro.url.searchParams.get(RETURN_TO_PARAM)

const loginUrl = new URL("/auth/login", Astro.url)
if (returnTo) {
	loginUrl.searchParams.set(RETURN_TO_PARAM, returnTo)
}
---

<Layout title="Authentication" viewer={viewer}>
	<section>
		<h1>Authentication</h1>
		<FlashBanners error={error} notice={notice} />

		{viewer ? (
			<p>
				Signed in as {viewer.displayName ?? viewer.email}. Continue to the{" "}
				<a href="/dashboard">dashboard</a> or sign out.
			</p>
		) : diagnostics.configured ? (
			<>
				<p>Keycloak is configured and ready for OIDC sign-in.</p>
				<p>
					<a href={`${loginUrl.pathname}${loginUrl.search}`}>Sign in with Keycloak</a>
				</p>
				{diagnostics.issuer ? <p>Issuer: {diagnostics.issuer}</p> : null}
			</>
		) : (
			<>
				<p>Keycloak configuration is incomplete.</p>
				<ul>
					{diagnostics.errors.map((err) => <li>{err}</li>)}
				</ul>
			</>
		)}
	</section>
</Layout>

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Authentication</title>
	</head>
	<body>
		<main>
			<h1>Authentication</h1>
			{noticeMessage && <p class="notice">{noticeMessage}</p>}
			{errorMessage && <p class="error">{errorMessage}</p>}

			{viewer ? (
				<section>
					<p>Signed in as <strong>{viewer.email}</strong>.</p>
					<form method="POST" action="/auth/logout">
						<button type="submit">Sign out</button>
					</form>
				</section>
			) : (
				<section>
					<p>Sign in with Keycloak to access the management dashboard.</p>
					<a class="button" href={`${loginUrl.pathname}${loginUrl.search}`}>Sign in with Keycloak</a>
				</section>
			)}

			{!diagnostics.configured && (
				<section class="diagnostics">
					<h2>Configuration Issues</h2>
					<ul>
						{diagnostics.errors.map((issue) => <li>{issue}</li>)}
					</ul>
				</section>
			)}
		</main>
	</body>
</html>

<style>
	main {
		margin: 0 auto;
		max-width: 840px;
		padding: 3rem 1.25rem;
		font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
	}

	h1 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.notice,
	.error {
		border-radius: 8px;
		padding: 0.75rem 1rem;
	}

	.notice {
		background: #e8f8ef;
		color: #165f36;
	}

	.error {
		background: #ffe9eb;
		color: #8d1c24;
	}

	.button,
	button {
		display: inline-block;
		padding: 0.55rem 1rem;
		border-radius: 8px;
		border: 1px solid #11263f;
		background: #11263f;
		color: #ffffff;
		text-decoration: none;
		cursor: pointer;
	}

	.diagnostics {
		margin-top: 1.5rem;
	}
</style>
