---
import { loadPageContext } from "../lib/page"
import { listApiTokens } from "../lib/models/api-token"
import { listUsers } from "../lib/models/user"

const [{ viewer, error, notice }, users, apiTokens] = await Promise.all([
	loadPageContext(Astro.request, Astro.response),
	listUsers(),
	listApiTokens()
])
---

<Layout title="Users" viewer={viewer}>
	<section>
		<h1>User Management</h1>
		<FlashBanners error={error} notice={notice} />
		<p>
			Admins can promote, demote, and enable or disable local dashboard access.
			Keycloak remains the authentication source.
		</p>
		<UsersTable users={users} viewerId={viewer?.id} />
		<ApiTokensPanel apiTokens={apiTokens} />
	</section>
</Layout>
