---
import Layout from "../components/Layout.astro"
import FlashBanners from "../components/ui/FlashBanners.astro"
import { loadPageContext } from "../lib/page"

const { viewer, error, notice } = await loadPageContext(
	Astro.request,
	Astro.response
)
---

<Layout title="Dashboard" viewer={viewer}>
	<section>
		<h1>Dashboard</h1>
		<FlashBanners error={error} notice={notice} />

		{viewer ? (
			<>
				<p>
					Signed in as {viewer.displayName ?? viewer.email} with local role{" "}
					{viewer.role}.
				</p>
				<p>
					OIDC login and first-admin bootstrap are wired. The next slices are
					link/domain workflows.
				</p>
				<p>
					Open the <a href="/links">links page</a> to create, update, search, or delete
					short links.
				</p>
				<p>
					Open the <a href="/domains">domains page</a> to add redirect hosts and verify
					their DNS.
				</p>
				{viewer.role === "admin" ? (
					<p>
						Open the <a href="/users">user-management page</a> to promote, demote, or
						disable local dashboard users.
					</p>
				) : null}
			</>
		) : null}
	</section>
</Layout>
