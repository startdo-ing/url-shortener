---
import Layout from "../components/Layout.astro"
import FlashBanners from "../components/ui/FlashBanners.astro"
import { loadPageContext } from "../lib/page"
import { listRecentClickEvents } from "../lib/models/analytics"

const [{ viewer, error, notice }, recentEvents] = await Promise.all([
	loadPageContext(Astro.request, Astro.response),
	listRecentClickEvents(100)
])
---

<Layout title="Recent Click Events" viewer={viewer}>
	<section>
		<h1>Recent Click Events</h1>
		<FlashBanners error={error} notice={notice} />
		<p>Latest traffic captured by the redirect service.</p>

		{recentEvents.length === 0 ? (
			<p>No click events recorded yet.</p>
		) : (
			<>
				<div class="responsive-table-desktop">
					<table class="data-table">
						<thead>
							<tr>
								<th>Occurred At</th>
								<th>Link</th>
								<th>Path</th>
								<th>Referrer</th>
								<th>Country</th>
							</tr>
						</thead>
						<tbody>
							{recentEvents.map((event) => (
								<tr>
									<td>{event.occurredAt}</td>
									<td>{event.domainHost}/{event.slug}</td>
									<td>{event.requestPath}</td>
									<td>{event.referer ?? "-"}</td>
									<td>{event.countryCode ?? "-"}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<div class="responsive-card-list">
					{recentEvents.map((event) => (
						<article class="responsive-card-item">
							<div class="responsive-card-grid">
								<div class="responsive-card-label">Occurred At</div>
								<div class="responsive-card-value">{event.occurredAt}</div>

								<div class="responsive-card-label">Link</div>
								<div class="responsive-card-value">{event.domainHost}/{event.slug}</div>

								<div class="responsive-card-label">Path</div>
								<div class="responsive-card-value">{event.requestPath}</div>

								<div class="responsive-card-label">Referrer</div>
								<div class="responsive-card-value">{event.referer ?? "-"}</div>

								<div class="responsive-card-label">Country</div>
								<div class="responsive-card-value">{event.countryCode ?? "-"}</div>
							</div>
						</article>
					))}
				</div>
			</>
		)}
	</section>
</Layout>
