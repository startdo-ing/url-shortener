---
import type { LinkDomainOption } from "../../lib/models/link"

interface Props {
	domains: LinkDomainOption[]
	actionPath?: string
	returnTo?: string
}

const { domains } = Astro.props
const actionPath = Astro.props.actionPath ?? "/dashboard"
const returnTo = Astro.props.returnTo ?? "/dashboard"

const HTTP_CODE_LABELS: Record<number, string> = {
	301: "301 Moved Permanently",
	302: "302 Found",
	307: "307 Temporary Redirect"
}
---


<div class="create-link-dialog-trigger">
	<button aria-label="Create Link" id="create-link-btn" type="button">
		<span aria-hidden="true" class="create-link-dialog-trigger__icon">↗</span>
		<span class="create-link-dialog-trigger__label">Create Link</span>
	</button>
</div>

<dialog id="create-link-dialog">
	<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--spacing-md)">
		<h2 style="margin:0">Create Link</h2>
		<button id="create-link-close-btn" type="button" data-variant="secondary" aria-label="Close">✕</button>
	</div>
	{domains.length === 0 ? (
		<p>Add a domain before creating short links.</p>
	) : (
		<form action={actionPath} method="post">
			<input name="intent" type="hidden" value="create" />
			<input name="returnTo" type="hidden" value={returnTo} />
			<div class="form-row">
				<span>Domain</span>
				<div class="radio-group">
					{domains.map((domain, i) => (
						<label>
							<input
								checked={i === 0}
								name="domainId"
								required
								type="radio"
								value={domain.id}
							/>
							{domain.host}
						</label>
					))}
				</div>
			</div>
			<div class="form-row">
				<label for="create-link-target-url">Target URL</label>
				<input
					id="create-link-target-url"
					name="targetUrl"
					placeholder="https://example.com/docs"
					required
					type="url"
				/>
			</div>
			<div class="form-row">
				<label for="create-link-slug">Slug</label>
				<div class="input-with-indicator">
					<input id="create-link-slug" name="slug" placeholder="docs" required type="text" />
					<div class="input-with-indicator__right" aria-live="polite">
						<span
							id="create-link-slug-loading"
							aria-hidden="true"
							class="input-with-indicator__spinner"
							hidden
						></span>
						<button
							id="create-link-slug-apply"
							aria-label="Use suggested slug"
							class="input-with-indicator__action"
							hidden
							title="Use suggested slug"
							type="button"
						>
							↺
						</button>
					</div>
				</div>
			</div>
			<div class="form-row">
				<span>HTTP code</span>
				<div class="radio-group">
					{[301, 302, 307].map((code) => (
						<label>
							<input
								checked={code === 307}
								name="httpCode"
								type="radio"
								value={String(code)}
							/>
							{HTTP_CODE_LABELS[code]}
						</label>
					))}
				</div>
			</div>
			<div class="form-row">
				<span>Status</span>
				<div class="radio-group">
					<label>
						<input checked name="status" type="radio" value="active" />
						Active
					</label>
					<label>
						<input name="status" type="radio" value="disabled" />
						Disabled
					</label>
				</div>
			</div>
			<div class="form-row">
				<label>
					Expiry (optional)
					<input name="expiresAt" type="datetime-local" />
				</label>
			</div>
			<div class="form-row">
				<label>
					Password (optional)
					<input
						name="password"
						placeholder="Leave empty for public access"
						type="password"
					/>
				</label>
			</div>
			<div class="form-actions form-actions--end">
				<button type="submit">Create Short Link</button>
			</div>
		</form>
	)}
</dialog>

<script>
	const btn = document.getElementById("create-link-btn")
	const dialog = document.getElementById("create-link-dialog") as HTMLDialogElement | null
	const closeBtn = document.getElementById("create-link-close-btn")
	const targetUrlInput = dialog?.querySelector<HTMLInputElement>("input[name='targetUrl']")
	const slugInput = dialog?.querySelector<HTMLInputElement>("input[name='slug']")
	const slugLoading = document.getElementById("create-link-slug-loading")
	const applySuggestionBtn = document.getElementById(
		"create-link-slug-apply"
	) as HTMLButtonElement | null

	let pendingRequestId = 0
	let activeRequestController: AbortController | null = null
	let slugEditedWhileLoading = false
	let suggestedSlug = ""

	function setLoading(isLoading: boolean) {
		slugLoading?.toggleAttribute("hidden", !isLoading)
	}

	function refreshSuggestionAction() {
		if (!applySuggestionBtn || !slugInput) {
			return
		}

		const currentSlug = slugInput.value.trim()
		const canApplySuggestion =
			suggestedSlug.length > 0 && currentSlug.length > 0 && currentSlug !== suggestedSlug

		applySuggestionBtn.hidden = !canApplySuggestion
	}

	async function maybeRecommendSlug() {
		if (!targetUrlInput || !slugInput) {
			return
		}

		if (slugInput.value.trim().length > 0) {
			return
		}

		const targetUrl = targetUrlInput.value.trim()
		if (targetUrl.length === 0) {
			return
		}

		activeRequestController?.abort()
		activeRequestController = new AbortController()
		slugEditedWhileLoading = false
		const requestId = ++pendingRequestId
		setLoading(true)

		try {
			const response = await fetch(
				`/api/links/recommend-slug?targetUrl=${encodeURIComponent(targetUrl)}`,
				{
					headers: { accept: "application/json" },
					signal: activeRequestController.signal
				}
			)

			if (!response.ok || requestId !== pendingRequestId) {
				return
			}

			const payload = (await response.json()) as { slug?: string }
			const recommendation = (payload.slug ?? "").trim()
			if (recommendation.length === 0) {
				return
			}

			suggestedSlug = recommendation

			if (!slugEditedWhileLoading && slugInput.value.trim().length === 0) {
				slugInput.value = recommendation
			}

			refreshSuggestionAction()
		} catch {
			// Ignore network failures; user can continue entering a slug manually.
		} finally {
			if (requestId === pendingRequestId) {
				setLoading(false)
				activeRequestController = null
			}
		}
	}

	btn?.addEventListener("click", () => {
		dialog?.showModal()
		requestAnimationFrame(() => targetUrlInput?.focus())
	})
	closeBtn?.addEventListener("click", () => dialog?.close())
	applySuggestionBtn?.addEventListener("click", () => {
		if (!slugInput || suggestedSlug.length === 0) {
			return
		}

		slugInput.value = suggestedSlug
		slugInput.focus()
		refreshSuggestionAction()
	})
	targetUrlInput?.addEventListener("blur", maybeRecommendSlug)
	targetUrlInput?.addEventListener("paste", () => {
		setTimeout(maybeRecommendSlug, 0)
	})
	slugInput?.addEventListener("input", () => {
		if (activeRequestController) {
			slugEditedWhileLoading = true
		}
		refreshSuggestionAction()
	})
</script>
