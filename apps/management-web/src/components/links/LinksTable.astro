---
import {
	formatShortLinkUrl,
	type ManagedShortLink,
	type LinkDomainOption
} from "../../lib/models/link"

interface Props {
	links: ManagedShortLink[]
	domains: LinkDomainOption[]
}

const { links, domains } = Astro.props
---

<h2>Existing Links</h2>
{links.length === 0 ? (
	<p>No short links match the current filters.</p>
) : (
	<table class="data-table">
		<thead>
			<tr>
				<th>Link</th>
				<th>Target</th>
				<th>Status</th>
				<th>HTTP</th>
				<th>Expires</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{links.map((link) => (
				<tr>
					{(() => {
						const shortUrl = formatShortLinkUrl(link.domainHost, link.slug)
						const isProtected = link.passwordHash != null

						return (
							<>
					<td>
						<a
							class="table-link"
							href={shortUrl}
							rel="noreferrer"
							target="_blank"
						>
							<span aria-hidden="true" class="table-link__icon">
								{isProtected ? "🔑" : "🌍"}
							</span>
							<strong>{shortUrl}</strong>
						</a>
					</td>
					<td>
						<a
							class="table-link"
							href={link.targetUrl}
							rel="noreferrer"
							target="_blank"
						>
							{link.targetUrl}
						</a>
					</td>
					<td>
						<span class={`badge badge--${link.status}`}>{link.status}</span>
					</td>
					<td>{link.httpCode}</td>
					<td>{link.expiresAt ?? "—"}</td>
					<td>
						<div class="row-actions">
							<details class="row-actions__details">
								<summary class="row-actions__summary">Edit</summary>
								<form action="/links" method="post">
									<input name="intent" type="hidden" value="update" />
									<input name="linkId" type="hidden" value={link.id} />
									<div class="form-row">
										<span>Domain</span>
										<div class="radio-group">
											{domains.map((domain) => (
												<label>
													<input
														checked={link.domainId === domain.id}
														name="domainId"
														required
														type="radio"
														value={domain.id}
													/>
													{domain.host}
												</label>
											))}
										</div>
									</div>
									<div class="form-row">
										<label>
											Slug
											<input
												name="slug"
												required
												type="text"
												value={link.slug}
											/>
										</label>
									</div>
									<div class="form-row">
										<label>
											Target URL
											<input
												name="targetUrl"
												required
												type="url"
												value={link.targetUrl}
											/>
										</label>
									</div>
									<div class="form-row">
										<span>HTTP code</span>
										<div class="radio-group">
											{[301, 302, 307].map((code) => (
												<label>
													<input
														checked={code === link.httpCode}
														name="httpCode"
														type="radio"
														value={String(code)}
													/>
													{code}
												</label>
											))}
										</div>
									</div>
									<div class="form-row">
										<span>Status</span>
										<div class="radio-group">
											<label>
												<input
													checked={link.status === "active"}
													name="status"
													type="radio"
													value="active"
												/>
												Active
											</label>
											<label>
												<input
													checked={link.status === "disabled"}
													name="status"
													type="radio"
													value="disabled"
												/>
												Disabled
											</label>
										</div>
									</div>
									<div class="form-row">
										<label>
											Expiry (optional)
											<input
												name="expiresAt"
												type="datetime-local"
												value={link.expiresAt ? link.expiresAt.slice(0, 16) : ""}
											/>
										</label>
									</div>
									<div class="form-row">
										<label>
											Password (optional)
											<input
												name="password"
												placeholder="Leave empty to keep current password"
												type="password"
											/>
										</label>
									</div>
									<div class="form-actions">
										<button type="submit">Save changes</button>
									</div>
								</form>
							</details>
							<form action="/links" method="post">
								<input name="intent" type="hidden" value="delete" />
								<input
									name="label"
									type="hidden"
									value={shortUrl}
								/>
								<input name="linkId" type="hidden" value={link.id} />
								<button data-variant="secondary" type="submit">Delete</button>
							</form>
						</div>
					</td>
							</>
						)
					})()}
				</tr>
			))}
		</tbody>
	</table>
)}
