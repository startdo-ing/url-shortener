---
import type { Viewer } from "../lib/models/user.ts"
import { hasPermission } from "../lib/auth/permissions.ts"
import "../styles/global.css"

interface Props {
	title: string
	viewer?: Viewer | null
}

const { title, viewer } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="shell">
			<header class="site-header">
				<nav class="site-nav">
					<a href="/">Home</a>
					{viewer ? <a href="/dashboard">Dashboard</a> : null}
					{viewer && hasPermission(viewer, "links:manage") ? <a href="/links">Links</a> : null}
					{viewer && hasPermission(viewer, "analytics:view") ? <a href="/analytics">Analytics</a> : null}
					{
						viewer && hasPermission(viewer, "domains:manage") ? (
							<a href="/domains">Domains</a>
						) : null
					}
					{viewer && hasPermission(viewer, "users:manage") ? <a href="/users">Users</a> : null}
				</nav>
				{
					viewer ? (
						<div class="site-user">
							<span>{viewer.displayName ?? viewer.email}</span>
							<form action="/auth/logout" method="post">
								<button type="submit">Sign out</button>
							</form>
						</div>
					) : null
				}
			</header>
			<main class="page-content">
				<slot />
			</main>
		</div>
	</body>
</html>
